# Flowfex uses Vite with envPrefix configured to expose NEXT_PUBLIC_* values to browser code.

# Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard -> Project Settings -> API -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase Dashboard -> Project Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Supabase Dashboard -> Project Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Your public frontend origin for local or deployed redirects, for example http://localhost:3000 or https://app.flowfex.com
VITE_APP_URL=http://localhost:3000

# The backend origin used by the frontend when it calls the Flowfex server, for example http://localhost:4000 or https://api.flowfex.com
VITE_BACKEND_URL=http://localhost:4000

# The public origin the backend uses when it generates connect links and live session URLs; normally this matches VITE_BACKEND_URL
FLOWFEX_PUBLIC_ORIGIN=http://localhost:4000

# Comma-separated frontend origins allowed by the Flowfex backend CORS and Socket.io layers; use your deployed frontend URL and localhost during development
ALLOWED_ORIGINS=http://localhost:3000

# Optional backend port override for local development
PORT=4000
