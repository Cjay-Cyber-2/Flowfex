# First taggable Flowfex version
# These are the minimum values to set for a first hosted version on:
# - Frontend: Vercel
# - Backend: Render

VITE_APP_URL=                        # https://app.yourdomain.com
VITE_BACKEND_URL=                    # https://api.yourdomain.com
FLOWFEX_PUBLIC_ORIGIN=               # https://api.yourdomain.com
ALLOWED_ORIGINS=                     # https://app.yourdomain.com,https://staging-app.yourdomain.com
FLOWFEX_LINK_SECRET=                 # openssl rand -hex 32
FLOWFEX_CONNECTION_API_KEY=          # Optional extra hardening for restricted server-to-server connection flows
PORT=4000                            # Local only. Render injects PORT in production.

# LLM Provider for real orchestration
# Use only one unless you intentionally want the current provider priority:
# GROQ_API_KEY -> OPENAI_API_KEY -> ANTHROPIC_API_KEY
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Later: Neon + Better Auth migration
# Leave these unset for the first tag unless you complete the remaining migration work.

# Neon Database
DATABASE_URL=                        # Neon connection string from Neon dashboard

# Better Auth
BETTER_AUTH_SECRET=                  # Random 32-byte secret: openssl rand -hex 32
BETTER_AUTH_URL=                     # Your backend base URL e.g. https://api.yourdomain.com

# OAuth Providers
GOOGLE_CLIENT_ID=                    # Google Cloud Console OAuth credentials
GOOGLE_CLIENT_SECRET=                # Google Cloud Console OAuth credentials
GITHUB_CLIENT_ID=                    # GitHub Developer Settings OAuth App
GITHUB_CLIENT_SECRET=                # GitHub Developer Settings OAuth App
TWITTER_CLIENT_ID=                   # Twitter Developer Portal OAuth 2.0 App
TWITTER_CLIENT_SECRET=               # Twitter Developer Portal OAuth 2.0 App
DISCORD_CLIENT_ID=                   # Discord Developer Portal Application
DISCORD_CLIENT_SECRET=               # Discord Developer Portal Application
MICROSOFT_CLIENT_ID=                 # Azure Portal App Registration
MICROSOFT_CLIENT_SECRET=             # Azure Portal App Registration
APPLE_CLIENT_ID=                     # Apple Developer Portal Service ID
APPLE_CLIENT_SECRET=                 # Apple Developer Portal private key

# Email Provider for magic links / email verification
EMAIL_FROM=                          # noreply@yourdomain.com
SMTP_HOST=                           # your SMTP provider host
SMTP_PORT=                           # 587 for TLS
SMTP_USER=                           # SMTP username
SMTP_PASS=                           # SMTP password
