{
  "name": "flowfex-backend",
  "version": "1.0.0",
  "description": "Flowfex Backend Orchestrator",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "build:orchestration": "node ./node_modules/typescript/bin/tsc -p tsconfig.orchestration.json",
    "typecheck:orchestration": "node ./node_modules/typescript/bin/tsc -p tsconfig.orchestration.json --noEmit",
    "start": "npm run build:orchestration && node src/server.js",
    "test": "npm run build:orchestration && node src/__tests__/orchestration-engine.test.js",
    "skills:sample": "node src/skills/sampleConversion.js",
    "skills:test-phase1": "node src/skills/testPhase1.js",
    "skills:test-phase2": "node src/skills/testPhase2.js",
    "skills:audit": "node src/skills/testPhase1.js",
    "skills:bulk-import": "node src/skills/runBulkImport.js",
    "skills:report": "node src/skills/runBulkImport.js --report-only"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
